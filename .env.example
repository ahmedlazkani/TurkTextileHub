# =============================================================================
# TopKap Telegram Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values before running the bot.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------

# Bot Token — obtained from @BotFather on Telegram
# Bot username: @TopKapTR_bot
TELEGRAM_BOT_TOKEN=8780372570:AAGZ9gNY8IjkT6g8j8qdzvp8ivAoPCmMpis

# Bot username (without @) — used for deep link generation
BOT_USERNAME=TopKapTR_bot

# Telegram user ID of the bot admin (for error alerts and admin commands)
ADMIN_TELEGRAM_ID=your-telegram-user-id-here

# -----------------------------------------------------------------------------
# KAYISOFT API
# -----------------------------------------------------------------------------

# Base URL for KAYISOFT backend (staging or production)
# Staging:    https://staging-api.kayisoft.com  (provided by KAYISOFT team)
# Production: https://api.kayisoft.com
KAYISOFT_BASE_URL=https://staging-api.kayisoft.com

# Static API key — acts like a Bearer token, does not expire
# Provided by KAYISOFT development team
KAYISOFT_API_KEY=your-kayisoft-api-key-here

# Webhook secret — used to verify incoming webhooks from KAYISOFT
KAYISOFT_WEBHOOK_SECRET=your-webhook-secret-here

# -----------------------------------------------------------------------------
# AI PROVIDER
# -----------------------------------------------------------------------------

# Choose the AI provider for product extraction and validation
# Options: deepseek | gemini | openai
# KAYISOFT team decision: DeepSeek (confirmed 2026-05-14)
AI_PROVIDER=deepseek

# DeepSeek API key — https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Gemini API key — https://aistudio.google.com (fallback if needed)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API key — https://platform.openai.com (fallback if needed)
OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# SUPABASE (Fallback database — used when KAYISOFT API is unavailable)
# -----------------------------------------------------------------------------

# Project URL — from https://supabase.com/dashboard/project/YOUR_ID/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key (server-side only, never expose to clients)
SUPABASE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# MOBILE APPS (Deep Links)
# -----------------------------------------------------------------------------

# TopKap — Supplier-facing app (iOS & Android)
# Used to generate deep links in channel posts: topkap://product/{id}
TOPKAP_APP_SCHEME=topkap
TOPKAP_WEB_URL=https://topkap.app

# TopGate — Buyer-facing app (iOS & Android)
# Used to generate deep links in channel posts: topgate://product/{id}
TOPGATE_APP_SCHEME=topgate
TOPGATE_WEB_URL=https://topgate.app

# -----------------------------------------------------------------------------
# WEBHOOK (Optional — for production deployment)
# -----------------------------------------------------------------------------

# Set WEBHOOK_MODE=true to run in webhook mode instead of polling
# Recommended for production servers
WEBHOOK_MODE=false

# Public HTTPS URL where Telegram will send updates (required if WEBHOOK_MODE=true)
# Example: https://bot.topkap.app/webhook
WEBHOOK_URL=

# Port to listen on (default: 8443)
WEBHOOK_PORT=8443

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
