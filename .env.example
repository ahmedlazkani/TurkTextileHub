# ===================================================
# TurkTextileHub Bot — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# ===================================================

# Telegram Bot Token — من @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Supabase — من https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# OpenAI API — لتحليل منشورات القناة تلقائياً
OPENAI_API_KEY=your-openai-api-key-here

# Telegram Admin ID — معرّف حساب التليجرام للمدير
ADMIN_TELEGRAM_ID=your-telegram-id-here
