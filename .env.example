# =============================================================================
# TopKap Telegram Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values before running the bot.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------

# Bot Token — obtained from @BotFather on Telegram
# Bot username: @TopKapTR_bot
BOT_TOKEN=your-telegram-bot-token-here

# Telegram user ID of the bot admin (for error alerts and admin commands)
ADMIN_TELEGRAM_ID=your-telegram-user-id-here

# -----------------------------------------------------------------------------
# KAYISOFT API
# -----------------------------------------------------------------------------

# Base URL for KAYISOFT backend (staging or production)
# Staging:    https://api-wholesale.dev.kayisoft.net
# Production: (provided by KAYISOFT team upon go-live)
KAYISOFT_API_URL=https://api-wholesale.dev.kayisoft.net

# API Endpoint Key — used as Bearer token for all API requests.
# This is the bot's own static API key, provided by the KAYISOFT team.
# It is sent in the Authorization header: "Bearer <key>"
TELEGRAM_BOT_API_ENDPOINT_KEY=your-kayisoft-api-endpoint-key-here

# Base URL for the Telegram deep link used to connect a supplier's account.
# The token from the app is appended to this URL.
# Format: https://t.me/<bot_username>?start=
TELEGRAM_BOT_CONNECT_BASE_URL=https://t.me/TopKapTR_bot?start=

# -----------------------------------------------------------------------------
# AI PROVIDER
# -----------------------------------------------------------------------------

# DeepSeek API key — https://platform.deepseek.com
# Used for AI-powered product attribute extraction and validation.
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# -----------------------------------------------------------------------------
# MOBILE APPS (Deep Links)
# -----------------------------------------------------------------------------

# TopKap — Supplier-facing app
TOPKAP_WEB_URL=https://topkap.app

# TopGate — Buyer-facing app
TOPGATE_WEB_URL=https://topgate.app

# -----------------------------------------------------------------------------
# PERSISTENCE
# -----------------------------------------------------------------------------

# Path to the JSON file that stores user → channel_id mappings.
# On Railway: set this to /app/data/user_channels.json and add a Volume
# mounted at /app/data to survive restarts.
# If not set, defaults to /data/user_channels.json (or /tmp as fallback).
# CHANNELS_FILE=/app/data/user_channels.json

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
